{
  "name": "adaptive-lyrics-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:js && npm run build:css && npm run copy:static",
    "build:js": "node esbuild.config.mjs",
    "build:css": "tailwindcss -i ./src/content/styles.css -o ./dist/content.css --minify",
    "copy:static": "node scripts/copy-static.mjs",
    "watch:js": "node esbuild.config.mjs --watch",
    "watch:css": "tailwindcss -i ./src/content/styles.css -o ./dist/content.css --watch"
  },
  "dependencies": {
    "@indic-transliteration/sanscript": "^1.3.3",
    "framer-motion": "^12.42.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.23.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4"
  }
}
